# 后端 REST 前缀（默认 /api，经 Vite 或 Nginx 反代；前后端分离部署时可设完整 URL）
# VITE_BASE_API=/api

# 请替换 APIKey（假使APIKey是key123456）和APISecret（假使APISecret是secret123456）
VITE_SPARK_KEY=key123456:secret123456
VITE_SILICONFLOW_KEY=sk-xxxxxx

# 测试助手：需求文档写入 requirement_docs（须在「知识库」创建）；可通过变量覆盖上传集合名（须与后端 REQUIREMENT_DOCS_COLLECTION / TEST_CASE_UPLOAD_COLLECTION 对齐）
# VITE_TEST_CASE_UPLOAD_COLLECTION=requirement_docs

# 可选：Langfuse 控制台根 URL（与后端 LANGFUSE_BASE_URL 一致即可）。设置且后端开启追踪时，助手回复工具栏显示「观测」跳转
# VITE_LANGFUSE_UI_ORIGIN=http://localhost:3000

# GitHub Pages 静态部署时使用 hash 路由（见 package.json build:gh-pages）
# VITE_ROUTER_MODE=hash
