# ============================
# Noesis 敏感 / 环境配置（.env）
#
# 仅放密钥、Token、APP_ENV 等环境相关项。
# 运行参数（HITL、skills_market、端口、超时、开关等）一律写在 config.yaml，
# 见 config.example.yaml → 复制为 config.yaml
# ============================

# 运行环境（决定加载 .env.{APP_ENV}）
APP_ENV=dev

# ========== PostgreSQL 密码（连接信息在 config.yaml）==========
POSTGRES_PASSWORD=your-postgres-password

# ========== LLM / Embedding / VLM API Key ==========
# Rerank 精排默认复用 EMBEDDING_MODEL_API_KEY；可选单独设置 RERANK_MODEL_API_KEY 覆盖
# VLM 图片描述（聊天附件兜底 / 知识库）默认复用 EMBEDDING_MODEL_API_KEY；可选 VLM_MODEL_API_KEY 覆盖
MODEL_API_KEY=sk-your-api-key-here
# OpenCode Zen（config.yaml: model.type=opencode）使用公开 Key：MODEL_API_KEY=public
EMBEDDING_MODEL_API_KEY=sk-your-api-key-here
# RERANK_MODEL_API_KEY=
VLM_MODEL_API_KEY=sk-your-api-key-here

# ========== Qdrant（可选）==========
# QDRANT_API_KEY=

# ========== Langfuse（可选）==========
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# ========== Web 检索（COMMON_QA / DEEP_RESEARCH）==========
# 未配置时自动回退 DuckDuckGo（搜索）与本地 HTTP（抓取）
# TAVILY_API_KEY=tvly-your-key-here

# ========== 沙箱 runner 内网鉴权（backend ↔ sandbox-runner）==========
# SANDBOX_RUNNER_TOKEN=

# ========== MCP 密钥（写入 platform/user mcp.json 的 ${VAR} 展开）==========
# Context7 文档 MCP（可选；未设也可连，额度可能受限）
# CONTEXT7_API_KEY=
