# ============================
# Noesis 敏感 / 环境配置（.env）
# 运行参数（模型名、阈值、端口等）见 config.example.yaml → 复制为 config.yaml
# ============================

# 运行环境（决定加载 .env.{APP_ENV}）
APP_ENV=dev

# ========== JWT ==========
JWT_SECRET_KEY=your-jwt-secret-key-here

# ========== MySQL 密码（连接信息在 config.yaml）==========
MYSQL_PASSWORD=your-mysql-password

# ========== LLM / Embedding API Key ==========
MODEL_API_KEY=sk-your-api-key-here
# OpenCode Zen（config.yaml: model.type=opencode）使用公开 Key：MODEL_API_KEY=public
EMBEDDING_MODEL_API_KEY=sk-your-api-key-here
# 可选：独立摘要模型 Key；留空则复用 MODEL_API_KEY
# SUMMARIZATION_MODEL_API_KEY=
# 可选：知识库文档内嵌图 VL 描述；留空则复用 MODEL_API_KEY
# VL_MODEL_API_KEY=
# VL_MODEL_NAME=Qwen3-VL-32B-Instruct

# ========== Qdrant（可选）==========
# QDRANT_API_KEY=

# ========== Langfuse（可选）==========
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# ========== Web 检索（COMMON_QA / DEEP_RESEARCH）==========
# 未配置时自动回退 DuckDuckGo（搜索）与本地 HTTP（抓取）
# TAVILY_API_KEY=tvly-your-key-here
