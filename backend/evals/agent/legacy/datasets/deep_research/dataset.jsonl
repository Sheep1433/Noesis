{"id": "dr_code_small_api_fix", "category": "code_intelligence", "query": "app.py 中 add 函数存在逻辑错误导致 test_app.py 失败。请修复并通过测试，将 pytest 结果摘要写入 results/test_summary.txt（需包含 passed 字样）。", "workspace_seed": "workspaces/dr_code_small_api_fix", "time_budget_seconds": 300, "ground_truth": {"criteria": [{"id": "c1", "type": "file_contains", "path": "app.py", "substring": "return a + b"}, {"id": "c2", "type": "file_exists", "path": "results/test_summary.txt"}, {"id": "c3", "type": "file_contains", "path": "results/test_summary.txt", "substring": "passed"}], "semantic_rubric": ["修复说明与测试通过状态一致"], "expected_tools": ["execute"]}, "provenance": "noesis:code_small_api_fix"}
