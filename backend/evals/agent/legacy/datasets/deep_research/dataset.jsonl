{"id": "dr_search_wiki_bio", "category": "search_retrieval", "query": "请从维基百科等公开来源检索一位 20 世纪著名物理学家的传记要点，在工作区创建 output/bio.md，包含「早年」「学术生涯」「主要贡献」三个二级标题，每节至少 2 句。", "workspace_seed": null, "time_budget_seconds": 600, "ground_truth": {"criteria": [{"id": "c1", "type": "file_exists", "path": "output/bio.md"}, {"id": "c2", "type": "file_contains", "path": "output/bio.md", "substring": "## 早年"}, {"id": "c3", "type": "file_contains", "path": "output/bio.md", "substring": "## 学术生涯"}], "semantic_rubric": ["传记内容包含可核实的人物姓名与年代", "三个章节均有实质叙述而非空标题"], "expected_tools": ["web_search"]}, "provenance": "adapted_from:WildClawBench:search_wiki_biography"}
