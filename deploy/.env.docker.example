# Docker 密钥（复制为 deploy/.env.docker，勿提交真实文件）
# 运行参数见 deploy/config.docker.yaml

APP_ENV=prod

# PostgreSQL（业务库 noesis，LangGraph checkpoint 库 noesis_langgraph）
POSTGRES_PASSWORD=__REPLACE__

MODEL_API_KEY=__REPLACE__
EMBEDDING_MODEL_API_KEY=__REPLACE__
# Rerank 精排默认复用 EMBEDDING_MODEL_API_KEY
VLM_MODEL_API_KEY=__REPLACE__

# QDRANT_API_KEY=

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# Web 检索（COMMON_QA / DEEP_RESEARCH；未配置时回退 DuckDuckGo / 本地 HTTP）
# TAVILY_API_KEY=tvly-your-key-here

# 沙箱 runner 内网鉴权（backend 与 sandbox-runner 须一致）
# SANDBOX_RUNNER_TOKEN=__REPLACE_WITH_RANDOM_TOKEN__

# Compose 宿主机绝对路径（Docker daemon bind source；须与挂进容器的路径字符串一致）
# NOESIS_HOST_DATA_DIR=/absolute/path/to/Noesis/.data
# NOESIS_HOST_SKILLS_DIR=/absolute/path/to/Noesis/extensions/skills
