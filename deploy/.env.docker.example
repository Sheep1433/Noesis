# Docker 密钥（复制为 deploy/.env.docker，勿提交真实文件）
# 运行参数见 deploy/config.docker.yaml

APP_ENV=prod

JWT_SECRET_KEY=__REPLACE_WITH_STRONG_RANDOM_SECRET__

# 数据库连接（同机双栈时共用 MySQL 实例，用库名区分：生产 noesis / 开发 noesis_dev）
# MYSQL_HOST=host.docker.internal
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_DATABASE=noesis
MYSQL_PASSWORD=__REPLACE__

MODEL_API_KEY=__REPLACE__
EMBEDDING_MODEL_API_KEY=__REPLACE__
RERANK_MODEL_API_KEY=__REPLACE__
VLM_MODEL_API_KEY=__REPLACE__

# QDRANT_API_KEY=

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# Web 检索（COMMON_QA / DEEP_RESEARCH；未配置时回退 DuckDuckGo / 本地 HTTP）
# TAVILY_API_KEY=tvly-your-key-here

# AIO 沙箱 runner 内网鉴权（backend 与 sandbox-runner 须一致）
# SANDBOX_RUNNER_TOKEN=__REPLACE_WITH_RANDOM_TOKEN__
